{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "typeRoots": ["../worker/node_modules/@types", "../worker/node_modules"],
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@linkedinpost/researcher": ["../packages/researcher/src/index.ts"],
      "zod": ["../frontend/node_modules/zod/index.d.ts"]
    }
  },
  "include": ["src/**/*"]
}
