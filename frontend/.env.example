# Copy to `.env` and adjust. See SETUP.md for full deployment env.

VITE_WORKER_URL=http://localhost:8787
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Local only: skip Google Sign-In when the Worker `local` env sets the same secret
# (see `env.local.vars.DEV_GOOGLE_AUTH_BYPASS_SECRET` in worker/wrangler.jsonc).
VITE_DEV_GOOGLE_AUTH_BYPASS=true
VITE_DEV_GOOGLE_AUTH_BYPASS_SECRET=local-dev-google-auth-bypass-linkedinpost
