# ALLOWED_EMAILS — optional. If set, only listed emails can log in.
# If empty or unset, any verified Google account can sign up.
# ALLOWED_EMAILS=friend1@gmail.com,friend2@gmail.com
ADMIN_EMAILS=you@gmail.com
# Optional local dev: skip Google Sign-In — set the same value as VITE_DEV_GOOGLE_AUTH_BYPASS_SECRET in frontend .env
# DEV_GOOGLE_AUTH_BYPASS_SECRET=use-a-long-random-string-only-on-localhost
# Optional label for the synthetic session (default dev-bypass@local.invalid)
# DEV_GOOGLE_AUTH_BYPASS_EMAIL=dev@example.com
# Optional local dev: same spreadsheet as production when preview KV has no shared-config (sheet id from the Google Sheet URL)
# DEV_SPREADSHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"linkedin-bot@your-project.iam.gserviceaccount.com","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}
# GITHUB_TOKEN_ENCRYPTION_KEY — required for encrypting OAuth tokens in D1.
# Generate with: openssl rand -hex 32
GITHUB_TOKEN_ENCRYPTION_KEY=your-32-byte-hex-key-here
CORS_ALLOWED_ORIGINS=http://localhost:5173 http://localhost:5174 http://127.0.0.1:5173 http://127.0.0.1:5174 https://your-username.github.io

# LLM providers — required for generation
GEMINI_API_KEY=your_gemini_api_key_here
# xAI Grok (optional — only needed when multi-provider LLM is enabled and you want Grok as primary/fallback)
XAI_API_KEY=your_xai_grok_api_key_here

# Generation Worker (optional — enables AI Draft in the dashboard)
# setup.py --cloudflare provisions D1; deploy requires GEMINI_API_KEY and/or XAI_API_KEY, then
# setup.py --deploy-worker deploys the generation worker and fills GENERATION_WORKER_URL / GENERATION_WORKER_SECRET (or set manually):
# GENERATION_WORKER_URL=https://your-generation-worker.your-account.workers.dev
# GENERATION_WORKER_SECRET=must-match-WORKER_SHARED_SECRET-on-the-generation-worker

# Scheduled publish auth secret (required for Durable Object alarm callbacks)
WORKER_SCHEDULER_SECRET=use-a-long-random-string

# News research API keys (optional — enable per-provider in Settings > News Research)
# NEWSAPI_KEY=your_newsapi_key_here
# GNEWS_API_KEY=your_gnews_key_here
# NEWSDATA_API_KEY=your_newsdata_key_here
# SERPAPI_API_KEY=your_serpapi_key_here

INSTAGRAM_APP_ID=your_instagram_app_id_here
INSTAGRAM_APP_SECRET=your_instagram_app_secret_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_PERSON_URN=urn:li:person:123456
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here

PIXAZO_API_KEY=your_pixazo_api_key_here