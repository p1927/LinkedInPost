# Setup and deployment
GOOGLE_SHARE_EMAIL=your_email@gmail.com
# ALLOWED_EMAILS — optional. If set, only listed emails can log in.
# If empty or unset, any verified Google account can sign up.
# ALLOWED_EMAILS=friend1@gmail.com,friend2@gmail.com
ADMIN_EMAILS=your_email@gmail.com
GITHUB_PAGES_ORIGIN=https://your-username.github.io
GITHUB_REPO=your-github-user/LinkedInPost
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
GITHUB_TOKEN_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# Frontend
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_WORKER_URL=https://your-worker.your-subdomain.workers.dev
# Local dev only: skip Google Sign-In — must match Worker DEV_GOOGLE_AUTH_BYPASS_SECRET in .dev.vars; secrets are embedded in the bundle (never use on a public URL against production)
# VITE_DEV_GOOGLE_AUTH_BYPASS=1
# VITE_DEV_GOOGLE_AUTH_BYPASS_SECRET=use-a-long-random-string-only-on-localhost
# Optional label for workspace header (match Worker DEV_GOOGLE_AUTH_BYPASS_EMAIL if set)
# VITE_DEV_GOOGLE_AUTH_BYPASS_EMAIL=dev@example.com

# Worker bootstrap
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"channel-bot@your-project.iam.gserviceaccount.com","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}

# Channel OAuth apps for dashboard connect flow
INSTAGRAM_APP_ID=your_instagram_app_id_here
INSTAGRAM_APP_SECRET=your_instagram_app_secret_here
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
GMAIL_CLIENT_ID=your_gmail_oauth_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_oauth_client_secret_here

# Optional Telegram bot delivery bootstrap
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Content generation and Google resources
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: Grok (xAI) when multiProviderLlm is true in features.yaml (Worker secret / .dev.vars)
# XAI_API_KEY=your_xai_api_key_here
# linkedin_bot draft LLM runs on the Worker (D1 `github_automation` + Worker secrets). GEMINI_API_KEY here is not required for GitHub draft if VITE_WORKER_URL + WORKER_SCHEDULER_SECRET are set.
# Optional: GOOGLE_MODEL in GitHub Actions client_payload / env (legacy hint for workflows; generation uses Worker keys + D1 settings).
# GOOGLE_MODEL=
SERPAPI_API_KEY=your_serpapi_api_key_here
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_CLOUD_STORAGE_BUCKET=your_public_gcs_bucket_here
GOOGLE_CLOUD_STORAGE_PREFIX=linkedin-images
GOOGLE_DOC_ID=your_google_doc_id_here
DELETE_UNUSED_GENERATED_IMAGES=true

# linkedin_bot.py: pipeline lives in Cloudflare D1 (must match deployed Worker + GitHub Actions secrets).
# VITE_WORKER_URL=https://your-worker.workers.dev
# WORKER_SCHEDULER_SECRET=your-scheduler-secret
# LINKEDIN_BOT_MIRROR_SHEET=false  # omit mirroring to Google Draft/Post; default is true

# Optional legacy direct publishing fallback
INSTAGRAM_USER_ID=your_instagram_user_id_here
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_PERSON_URN=urn:li:person:123456

# Optional legacy Meta WhatsApp Cloud API fallback
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
TELEGRAM_CHANNEL_ID=your_telegram_channel_id_here
# Optional news research (Worker secrets — Settings → News toggles which providers run)
# NewsAPI.org: developer/free tier is not for commercial use; headlines can be delayed ~24h.
NEWSAPI_KEY=
# GNews: free tier limits and ~12h delay on some plans.
GNEWS_API_KEY=
# NewsData.io: typically paid; optional second index.
NEWSDATA_API_KEY=
# SerpApi: shared with Google News researcher and image search (same monthly quota).
# SERPAPI_API_KEY is listed above with content generation.
# Bootstrap RSS URLs: comma- or newline-separated, or a JSON array string. Merged with feeds saved in Settings → News.
RESEARCHER_RSS_FEEDS=


PIXAZO_API_KEY=your_pixazo_api_key_here