#!/usr/bin/env python3
"""
LinkedInPost dev CLI — interactive menu until you choose Exit.

Usage:
  ./linked
  python3 linked
"""

from __future__ import annotations

import os
import re
import shutil
import signal
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent
WORKER = ROOT / "worker"
FRONTEND = ROOT / "frontend"
FEATURES_YAML = ROOT / "features.yaml"
GENERATE_FEATURES = ROOT / "scripts" / "generate_features.py"
SETUP_PY = ROOT / "setup.py"
WRANGLER = WORKER / "wrangler.jsonc"


def _d1_database_name() -> str:
    """Read database_name from worker/wrangler.jsonc (tolerates // comments)."""
    if not WRANGLER.is_file():
        return "linkedin-pipeline-db"
    raw = WRANGLER.read_text(encoding="utf-8")
    # Strip // comments for a crude parse
    lines = [ln.split("//", 1)[0] for ln in raw.splitlines()]
    stripped = "\n".join(lines)
    m = re.search(r'"database_name"\s*:\s*"([^"]+)"', stripped)
    return m.group(1) if m else "linkedin-pipeline-db"


def _run(
    cmd: list[str],
    *,
    cwd: Path | None = None,
    env: dict | None = None,
    stdin_disconnect: bool = False,
) -> int:
    print(f"\n→ {' '.join(cmd)}\n", flush=True)
    kw: dict = {}
    if stdin_disconnect:
        kw["stdin"] = subprocess.DEVNULL
    try:
        return subprocess.call(cmd, cwd=cwd or ROOT, env=env, **kw)
    except FileNotFoundError as e:
        print(f"Command not found: {e}", file=sys.stderr)
        return 127


def _which_npm() -> str | None:
    return shutil.which("npm")


def _which_python() -> str:
    return sys.executable


def menu_setup() -> None:
    py = _which_python()
    npm = _which_npm()
    while True:
        print(
            """
Setup
  1) python3 setup.py (Google resources)
  2) python3 setup.py --cloudflare (provision KV/D1, write .dev.vars)
  3) python3 setup.py --all (full: Google + Cloudflare + deploy + GitHub sync)
  4) Setup wizard — web UI  (localhost:4242, Flask)
  5) Deploy generation worker
  0) Back to main menu
"""
        )
        c = input("Choice: ").strip()
        if c == "0":
            return
        if c == "1":
            _run([py, str(SETUP_PY)], cwd=ROOT)
            input("\nPress Enter to return to the main menu… ")
            return
        if c == "2":
            _run([py, str(SETUP_PY), "--cloudflare"], cwd=ROOT)
            input("\nPress Enter to return to the main menu… ")
            return
        if c == "3":
            _run([py, str(SETUP_PY), "--all"], cwd=ROOT)
            input("\nPress Enter to return to the main menu… ")
            return
        if c == "4":
            print("\nStarting web setup wizard at http://localhost:4242 …")
            print("Open that URL in your browser, then press Ctrl+C here when done.\n")
            _run([py, str(SETUP_PY), "--web"], cwd=ROOT)
            input("\nPress Enter to return to the main menu… ")
            return
        if c == "5":
            if not npm:
                print("npm not found; install Node.js first.")
                input("\nPress Enter to return to the main menu… ")
                return
            GEN_WORKER = ROOT / "generation-worker"
            _run([npm, "run", "deploy"], cwd=GEN_WORKER)
            input("\nPress Enter to return to the main menu… ")
            return
        print("Unknown option. Choose 0–5.")


def menu_migrations() -> None:
    db = _d1_database_name()
    npm = _which_npm()
    if not npm:
        print("npm not found; install Node.js or use: cd worker && npx wrangler d1 migrations apply ...")
        input("\nPress Enter to return to the main menu… ")
        return
    base = [npm, "exec", "wrangler", "d1", "migrations", "apply", db]
    while True:
        print(
            f"""
D1 migrations (database: {db})
  1) Apply --local
  2) Apply --remote
  0) Back to main menu
"""
        )
        c = input("Choice: ").strip()
        if c == "0":
            return
        if c == "1":
            _run(base + ["--local"], cwd=WORKER, stdin_disconnect=True)
            input("\nPress Enter to return to the main menu… ")
            return
        if c == "2":
            confirm = input("Apply to REMOTE D1? Type yes: ").strip().lower()
            if confirm == "yes":
                _run(base + ["--remote"], cwd=WORKER, stdin_disconnect=True)
            else:
                print("Cancelled.")
            input("\nPress Enter to return to the main menu… ")
            return
        print("Unknown option. Choose 0–2.")


def menu_run_locally() -> None:
    npm = _which_npm()
    if not npm:
        print("npm not found.")
        input("\nPress Enter to return to the main menu… ")
        return
    while True:
        print(
            """
Run locally
  1) Worker only (wrangler dev --env local)
  2) Frontend only (Vite)
  3) Worker + Frontend (worker in background, then frontend)
  0) Back to main menu
"""
        )
        c = input("Choice: ").strip()
        if c == "0":
            return
        if c == "1":
            _run([npm, "run", "dev"], cwd=WORKER)
            input("\nPress Enter to return to the main menu… ")
            return
        if c == "2":
            _run([npm, "run", "dev"], cwd=FRONTEND)
            input("\nPress Enter to return to the main menu… ")
            return
        if c == "3":
            worker_proc: subprocess.Popen | None = None
            try:
                worker_proc = subprocess.Popen(
                    [npm, "run", "dev"],
                    cwd=WORKER,
                    start_new_session=True,
                    stdin=subprocess.DEVNULL,
                )
                print(
                    f"Worker PID {worker_proc.pid}. Starting frontend… "
                    "(Ctrl+C stops frontend; worker will be terminated)\n"
                )
                _run([npm, "run", "dev"], cwd=FRONTEND)
            except KeyboardInterrupt:
                print("\nInterrupted.")
            finally:
                if worker_proc and worker_proc.poll() is None:
                    _terminate_process_tree(worker_proc.pid)
                    try:
                        worker_proc.wait(timeout=15)
                    except subprocess.TimeoutExpired:
                        worker_proc.kill()
            input("\nPress Enter to return to the main menu… ")
            return
        print("Unknown option. Choose 0–3.")


def _terminate_process_tree(pid: int) -> None:
    """Stop a dev server started with start_new_session=True (Unix PGID == pid)."""
    if sys.platform == "win32":
        subprocess.run(
            ["taskkill", "/PID", str(pid), "/T", "/F"],
            capture_output=True,
            check=False,
        )
        return
    try:
        os.killpg(os.getpgid(pid), signal.SIGTERM)
    except (ProcessLookupError, PermissionError, OSError):
        try:
            os.kill(pid, signal.SIGTERM)
        except ProcessLookupError:
            pass


def menu_features() -> None:
    py = _which_python()
    while True:
        print(
            """
Features (features.yaml → generated TypeScript)
  1) Show features.yaml
  2) Regenerate worker + frontend feature flags
  0) Back to main menu
"""
        )
        c = input("Choice: ").strip()
        if c == "0":
            return
        if c == "1":
            if FEATURES_YAML.is_file():
                print(f"\n--- {FEATURES_YAML} ---\n")
                print(FEATURES_YAML.read_text(encoding="utf-8"))
            else:
                print(f"Missing {FEATURES_YAML}")
            input("\nPress Enter to return to the main menu… ")
            return
        if c == "2":
            if not GENERATE_FEATURES.is_file():
                print(f"Missing {GENERATE_FEATURES}")
                input("\nPress Enter to return to the main menu… ")
                return
            _run([py, str(GENERATE_FEATURES)], cwd=ROOT, stdin_disconnect=True)
            input("\nPress Enter to return to the main menu… ")
            return
        print("Unknown option. Choose 0–2.")


def main_menu() -> None:
    while True:
        print(
            """
╔ LinkedInPost — linked CLI ═══════════════════════╗
║  1) Run setup                                 ║
║  2) Run D1 migrations                         ║
║  3) Run locally (worker / frontend / both)    ║
║  4) Features (view yaml, regenerate flags)    ║
║  0) Exit                                      ║
╚═══════════════════════════════════════════════╝
"""
        )
        choice = input("Select: ").strip().lower()
        if choice in ("0", "q", "quit", "exit"):
            print("Bye.")
            break
        if choice == "1":
            menu_setup()
        elif choice == "2":
            menu_migrations()
        elif choice == "3":
            menu_run_locally()
        elif choice == "4":
            menu_features()
        else:
            print("Unknown option. Choose 0–4.")


if __name__ == "__main__":
    if not ROOT.joinpath("worker").is_dir() or not ROOT.joinpath("frontend").is_dir():
        print("Run this script from the LinkedInPost repository root.", file=sys.stderr)
        sys.exit(1)
    try:
        main_menu()
    except KeyboardInterrupt:
        print("\nBye.")
        sys.exit(130)
