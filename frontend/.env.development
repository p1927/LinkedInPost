# Loaded by Vite in `npm run dev` only (overrides duplicate keys from `.env`).
# Matches `DEV_GOOGLE_AUTH_BYPASS_SECRET` in worker `wrangler.jsonc` → `env.local.vars`.
VITE_WORKER_URL=http://localhost:8787
VITE_DEV_GOOGLE_AUTH_BYPASS=true
VITE_DEV_GOOGLE_AUTH_BYPASS_SECRET=local-dev-google-auth-bypass-linkedinpost
