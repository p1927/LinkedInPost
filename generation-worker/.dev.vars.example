# LLM providers
GEMINI_API_KEY=your_gemini_api_key_here
XAI_API_KEY=your_xai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Image generation
# Fal.ai — backs Flux Kontext, Ideogram, Kling, Seedance providers
FAL_API_KEY=your_fal_api_key_here
PIXAZO_API_KEY=your_pixazo_api_key_here
# OpenAI — backs DALL-E provider
OPENAI_API_KEY=your_openai_api_key_here
STABILITY_API_KEY=your_stability_api_key_here
RUNWAY_API_KEY=your_runway_api_key_here

# Research
SERPAPI_API_KEY=your_serpapi_api_key_here

# Worker auth — must match GENERATION_WORKER_SECRET in worker/.dev.vars
# Generate with: openssl rand -base64 32
WORKER_SHARED_SECRET=use-a-long-random-string
